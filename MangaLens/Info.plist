<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>MangaLens</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>

	<!-- Camera: scanning manga panels -->
	<key>NSCameraUsageDescription</key>
	<string>MangaLens needs camera access to scan manga panels and detect Japanese or Korean text for translation.</string>

	<!-- Photos: selecting screenshots to translate -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>MangaLens needs photo library access to select manga screenshots for translation.</string>

	<!-- Photos: saving translated screenshots -->
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>MangaLens can save annotated screenshots with translation overlays to your photo library.</string>

	<!-- Microphone: ReplayKit captures audio alongside screen video -->
	<key>NSMicrophoneUsageDescription</key>
	<string>MangaLens uses your microphone as part of iOS screen recording (ReplayKit). No audio is stored or transmitted.</string>

	<!-- Screen recording: live translation via ReplayKit -->
	<key>NSReplayKitUsageDescription</key>
	<string>MangaLens records your screen to detect and translate manga speech bubbles in real time. No recording is saved or shared.</string>

	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict/>
	</dict>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>MinimumOSVersion</key>
	<string>16.0</string>
</dict>
</plist>
